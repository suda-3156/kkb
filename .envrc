#!/usr/bin/env bash

# DO NOT ADD SECRET KEYS HERE
# This file is used to load environment variables from the .env file

# Example:
#   ENV=                                // Required variable
#   ENV= #regex=^(local|dev|stg|prod)$  // Validate with regex
#   ENV= #optional                      // Optional variable

# Load
if [ ! -f "./.env.local" ]; then
    echo "WARNING: .env.local not found in the current directory." >&2

    if [ -f "./.env.example" ]; then
        cp .env.example .env.local
        echo "A new .env.local file has been created from .env.example. Please update it with your values."
        # exit 1 # Try to load generated .env.local
        sleep 1
    else
        exit 0
    fi
fi

dotenv ./.env.local

# Check if the required environment variables are set
required_vars=$(
    cat .env.example | grep -v '^#' | grep -v '#optional' | awk -F '=' '{print $1}' | tr '\n' ' '
)

for var in $required_vars; do
    if [ -z "${!var}" ]; then
        echo "ERROR: Required environment variable '$var' is not set." >&2
        exit 1
    fi
done

# Validate environment variables with regex patterns
while IFS= read -r line; do
    # Skip empty lines and comment lines
    [[ -z "$line" || "$line" =~ ^# ]] && continue

    # Check if line contains #regex=
    if [[ "$line" =~ \#regex=(.+)$ ]]; then
        regex_pattern="${BASH_REMATCH[1]}"
        var_name=$(echo "$line" | awk -F '=' '{print $1}' | xargs)
        var_value="${!var_name}"

        # Skip validation if variable is not set and is optional
        if [[ "$line" =~ \#optional ]] && [[ -z "$var_value" ]]; then
            continue
        fi

        # Validate with regex
        if [[ -n "$var_value" ]] && ! [[ "$var_value" =~ $regex_pattern ]]; then
            echo "ERROR: Environment variable '$var_name' value '$var_value' does not match pattern '$regex_pattern'." >&2
            exit 1
        fi
    fi
done < .env.example
