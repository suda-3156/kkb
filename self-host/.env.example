# Copy to .env and fill in. Used by docker-compose.yml interpolation.

PROJECT_NAME=kkb
TZ=Asia/Tokyo

DATA_ROOT=/mnt/ssd/kkb

# DB_NAME / DB_USER must match db/docker/init/init.sql (kkb_db / user).
DB_NAME=kkb_db
DB_USER=user
DB_PASSWORD=change-me-app
DB_ROOT_PASSWORD=change-me-root

ENCRYPTION_KMS_KEY_ID=system/ledger-encryption-key
ENCRYPTION_CACHE_TTL=5m
ENCRYPTION_AAD=

LOG_LEVEL=INFO
LOG_MODE=json

# tailnet ip address of the serving device
TAILSCALE_IP=100.100.100.100
