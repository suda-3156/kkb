# Copy to .env and fill in. Used by docker-compose.yml interpolation.

# Compose project name (also names the built API image and network).
PROJECT_NAME=kkb
TZ=Asia/Tokyo

# Absolute path to persistent storage on the external SSD (NOT the microSD).
# Holds MySQL data, encryption keys and secrets. See README.md.
DATA_ROOT=/mnt/ssd/kkb

# --- Database ---
# DB_NAME / DB_USER must match db/docker/init/init.sql (kkb_db / user).
DB_NAME=kkb_db
DB_USER=user
DB_PASSWORD=change-me-app
DB_ROOT_PASSWORD=change-me-root

# --- Encryption (FILESYSTEM key/secret managers) ---
# Key ID created by the bootstrap step (group/name). Do not change.
ENCRYPTION_KMS_KEY_ID=system/ledger-encryption-key
# In-memory key cache TTL.
ENCRYPTION_CACHE_TTL=5m
# Additional Authenticated Data for ledger encryption. Generate ONCE and never
# change it (changing it makes existing encrypted data undecryptable):
#   tr -dc A-Za-z0-9 </dev/urandom | head -c 16
ENCRYPTION_AAD=

# --- Public URL (Tailscale) ---
# Your tailnet HTTPS URL, used for backend CORS (ALLOWED_ORIGINS).
# e.g. https://kkb.<your-tailnet>.ts.net
PUBLIC_URL=https://kkb.example.ts.net

# --- Logging (optional) ---
LOG_LEVEL=INFO
LOG_MODE=json
